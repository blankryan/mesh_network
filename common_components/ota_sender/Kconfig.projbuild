# This menu used to live in main/Kconfig.projbuild guarded by
# `depends on MESH_NODE_ROLE_GATEWAY`. Now that the gateway is its own product
# and this component is only a dependency of that product, the guard (and the
# whole MESH_NODE_ROLE choice) is gone: the menu simply doesn't exist in the
# worker's menuconfig because the worker never pulls this component in.

menu "Gateway OTA sender"

choice GATEWAY_OTA_SOURCE
    prompt "Firmware source for a push"
    default GATEWAY_OTA_SRC_LOOPBACK
    help
        Where the gateway gets the image it pushes to a worker over ESP-NOW.

    config GATEWAY_OTA_SRC_LOOPBACK
        bool "Loopback (stream the gateway's own running app) - no AP needed"
        help
            Sends a copy of the gateway's running firmware to the target worker.
            Lets you exercise the responder + rollback end-to-end on the bench
            without an HTTP server. (The worker then runs the gateway image.)

    config GATEWAY_OTA_SRC_HTTP
        bool "HTTP/HTTPS download (leg 1) then ESP-NOW push (leg 2)"
        help
            Connects to an AP, downloads a worker image into a flash staging
            slot, returns to the ESP-NOW channel, then pushes it. Production path.

endchoice

config GATEWAY_OTA_HTTP_URL
    string "Firmware image URL"
    depends on GATEWAY_OTA_SRC_HTTP
    default "https://example.com/worker.bin"

config GATEWAY_OTA_WIFI_SSID
    string "Wi-Fi SSID for the leg-1 download"
    depends on GATEWAY_OTA_SRC_HTTP
    default "myssid"

config GATEWAY_OTA_WIFI_PASS
    string "Wi-Fi password for the leg-1 download"
    depends on GATEWAY_OTA_SRC_HTTP
    default "mypassword"

endmenu
