# Worker role overrides, layered on top of sdkconfig.defaults.
# Applied by the "worker" preset in CMakePresets.json
# (SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.worker").
#
# The target (esp32) is set by the preset's IDF_TARGET cache variable, not here.

# Compile worker_main.c (SSD1306 OLED + dummy sensor). See main/Kconfig.projbuild.
CONFIG_MESH_NODE_ROLE_WORKER=y

# OTA rollback: safe to enable now that the worker runs a PENDING_VERIFY
# self-test (ota_responder.c) and calls esp_ota_mark_app_valid_cancel_rollback()
# after a good boot. A crash/hang/power-loss before that confirm auto-rolls back.
# The bootloader RTC watchdog (CONFIG_BOOTLOADER_WDT_ENABLE) stays on by default.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
